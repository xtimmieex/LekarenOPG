<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox prefHeight="500.0" prefWidth="800.0" spacing="15.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sk.spse.javafx.Controller">
   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>

   <VBox prefWidth="250.0" spacing="10.0" style="-fx-background-color: #f4f4f4; -fx-padding: 10;">
      <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Hlavné menu" />
      <Separator />

      <Button maxWidth="Infinity" onAction="#ukazPodlaLatky" text="1. Lieky podľa účinnej látky" />
      <Button maxWidth="Infinity" onAction="#ukazVsetky" text="2. Všetky lieky" />
      <Button maxWidth="Infinity" onAction="#ukazExpirovane" text="3. Expirované lieky" />
      <Button maxWidth="Infinity" onAction="#vyhladatLiek" text="4. Vyhľadať liek (podľa názvu)" />
      <Separator />
      <Button maxWidth="Infinity" onAction="#pridatLiek" style="-fx-base: lightgreen;" text="5. Pridať nový liek" />
      <Button maxWidth="Infinity" onAction="#predatLiek" text="6. Predaj vybraného lieku" />
      <Button maxWidth="Infinity" onAction="#vyraditLiek" text="7. Vyradiť vybraný liek" />
      <Button maxWidth="Infinity" onAction="#vyraditExpirovane" style="-fx-base: #ffcccc;" text="8. Vyradiť všetky expirované" />
   </VBox>

   <VBox spacing="10.0" HBox.hgrow="ALWAYS">
      <Label style="-fx-font-weight: bold;" text="Zoznam liekov:" />

      <TableView fx:id="tabulkaLiekov" VBox.vgrow="ALWAYS">
         <columns>
            <TableColumn fx:id="colNazov" prefWidth="130.0" text="Názov lieku" />
            <TableColumn fx:id="colLatka" prefWidth="130.0" text="Účinná látka" />
            <TableColumn fx:id="colKusy" prefWidth="70.0" text="Kusy" />
            <TableColumn fx:id="colCena" prefWidth="70.0" text="Cena (€)" />
            <TableColumn fx:id="colExpiracia" prefWidth="100.0" text="Expirácia" />
         </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>

      <Label fx:id="infoLabel" style="-fx-text-fill: blue;" text="Vitajte v lekárni." />
   </VBox>

</HBox>